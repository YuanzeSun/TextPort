{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "textport",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-10",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "textport_db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
